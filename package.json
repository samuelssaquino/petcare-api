{
  "name": "petcare-api",
  "version": "1.0.0",
  "description": "API Rest para cadastro e consulta de pets.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --test",
    "test:unit": "node --test",
    "test:api": "mocha \"tests/api/**/*.spec.js\" --timeout 15000",
    "test:api:local": "set BASE_URL=http://localhost:3000&& npm run test:api",
    "test:api:vercel": "set BASE_URL=https://petcare-api-seven.vercel.app&& npm run test:api"
  },
  "keywords": [
    "api",
    "express",
    "mongodb",
    "jwt",
    "pets"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "wait-on": "^9.0.10"
  }
}
